{
  "name": "diffcore",
  "displayName": "diffcore",
  "description": "Semantic diff review — ranked, grouped code review flows for AI-generated PRs",
  "version": "0.1.0",
  "publisher": "diffcore",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "diffcore.analyze",
        "title": "Analyze Current Branch",
        "category": "diffcore",
        "icon": "$(search)"
      },
      {
        "command": "diffcore.analyzeRange",
        "title": "Analyze Commit Range",
        "category": "diffcore"
      },
      {
        "command": "diffcore.annotate",
        "title": "Annotate with LLM",
        "category": "diffcore",
        "icon": "$(sparkle)"
      },
      {
        "command": "diffcore.nextFile",
        "title": "Next File in Flow",
        "category": "diffcore"
      },
      {
        "command": "diffcore.prevFile",
        "title": "Previous File in Flow",
        "category": "diffcore"
      },
      {
        "command": "diffcore.nextGroup",
        "title": "Next Flow Group",
        "category": "diffcore"
      },
      {
        "command": "diffcore.prevGroup",
        "title": "Previous Flow Group",
        "category": "diffcore"
      },
      {
        "command": "diffcore.openAnnotations",
        "title": "Show Annotations Panel",
        "category": "diffcore",
        "icon": "$(book)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "diffcore",
          "title": "diffcore",
          "icon": "$(git-compare)"
        }
      ]
    },
    "views": {
      "diffcore": [
        {
          "id": "diffcore.groups",
          "name": "Flow Groups"
        },
        {
          "id": "diffcore.infrastructure",
          "name": "Infrastructure"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "diffcore.analyze",
          "when": "view == diffcore.groups",
          "group": "navigation"
        },
        {
          "command": "diffcore.annotate",
          "when": "view == diffcore.groups",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "diffcore.nextFile",
        "key": "j",
        "when": "diffcore.active && !editorFocus && !inputFocus"
      },
      {
        "command": "diffcore.prevFile",
        "key": "k",
        "when": "diffcore.active && !editorFocus && !inputFocus"
      },
      {
        "command": "diffcore.nextGroup",
        "key": "shift+j",
        "when": "diffcore.active && !editorFocus && !inputFocus"
      },
      {
        "command": "diffcore.prevGroup",
        "key": "shift+k",
        "when": "diffcore.active && !editorFocus && !inputFocus"
      }
    ],
    "configuration": {
      "title": "diffcore",
      "properties": {
        "diffcore.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to the diffcore CLI binary. Leave empty to use PATH."
        },
        "diffcore.defaultBase": {
          "type": "string",
          "default": "main",
          "description": "Default base branch for analysis."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
